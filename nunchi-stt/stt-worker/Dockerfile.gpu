FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

WORKDIR /app

ARG WHISPER_MODEL_SIZE=medium

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV WHISPER_MODEL_SIZE=${WHISPER_MODEL_SIZE}
ENV WHISPER_MODEL_DIR=/models/faster-whisper

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        ffmpeg \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/bin/python3 /usr/bin/python

COPY requirements.txt .

RUN python -m pip install --no-cache-dir --upgrade pip \
    && python -m pip install --no-cache-dir -r requirements.txt

RUN mkdir -p "${WHISPER_MODEL_DIR}/${WHISPER_MODEL_SIZE}" \
    && python -c "import os; from pathlib import Path; from faster_whisper.utils import download_model; model_dir = Path(os.environ['WHISPER_MODEL_DIR']) / os.environ['WHISPER_MODEL_SIZE']; download_model(os.environ['WHISPER_MODEL_SIZE'], output_dir=str(model_dir)); assert (model_dir / 'model.bin').is_file(), model_dir"

COPY app app
COPY run_api.py .
COPY run_worker.py .
COPY run_schedule.py .

EXPOSE 8090

ENTRYPOINT ["python", "run_api.py"]
